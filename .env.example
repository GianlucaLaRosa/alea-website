# --- Vercel environments (Settings → Environment Variables) ---
# Assign each variable to Production, Preview, and/or Development.
# - Production: prod DB + secrets + NEXT_PUBLIC_SERVER_URL = https://your-domain.com
# - Preview: use a separate POSTGRES_URL (e.g. Neon branch / staging DB) if you must not migrate prod.
#   Set NEXT_PUBLIC_SERVER_URL to the preview URL (e.g. https://<deployment>.vercel.app) so links/previews work.
# - Development: values for `vercel dev` / local .env
#
# Database connection string (Vercel Postgres / Neon / local)
POSTGRES_URL=postgresql://127.0.0.1:5432/your-database-name
# Used to encrypt JWT tokens (use different values per environment)
PAYLOAD_SECRET=YOUR_SECRET_HERE
# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Vercel Blob — media uploads (from Vercel → Storage → Blob → .env.local snippet)
BLOB_READ_WRITE_TOKEN=
# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE
# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE